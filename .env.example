# Claudio - AI 情感电台

## 环境变量配置

复制此文件为 `.env` 并填入实际值：
```bash
cp .env.example .env
```

### 必填变量

# 网易云音乐 Cookie（MUSIC_U=xxx，浏览器登录后从 cookie 中复制，获取方式见下方说明）
# 用于获取高音质和 VIP 歌曲的播放链接，非 VIP 歌曲不需要
NETEASE_COOKIE=

# MiMo API Key
MIMO_API_KEY=

# MiMo API 地址
MIMO_API_BASE=https://api.xiaomimimo.com/v1

# MiMo TTS 模型
# 可选：mimo-v2.5-tts | mimo-v2.5-tts-voicedesign | mimo-v2.5-tts-voiceclone
MIMO_TTS_MODEL=mimo-v2.5-tts

# MiMo 默认音色（仅作为后端默认值；运行时可在前端切换）
MIMO_TTS_VOICE=冰糖

# VoiceClone 模式使用的音频样本路径（.wav 或 .mp3）
MIMO_TTS_VOICE_SAMPLE_PATH=

# 广播服务端口
PORT=3000

# 电台时区；用于后端给 AI DJ 的当前时间上下文，避免服务器 UTC 时区导致文案时间错误
CLAUDIO_TIME_ZONE=Asia/Hong_Kong

# LLM API Key（OpenAI-compatible）
LLM_API_KEY=

# LLM Base URL（例如 https://api.example.com/v1）
BASE_URL=

# LLM 模型名
MODEL=

# 多 LLM 配置（可选）
# LLM_PROVIDER_ORDER 留空时使用上面的单 LLM 配置；填入后按顺序 fallback
# provider 名称只用于环境变量前缀和日志，不影响模型能力
# 示例：先用 primary，失败后切 backup
LLM_PROVIDER_ORDER=

LLM_PRIMARY_API_KEY=
LLM_PRIMARY_BASE_URL=https://api.example.com/v1
LLM_PRIMARY_MODEL=
LLM_PRIMARY_TIMEOUT_MS=60000

LLM_BACKUP_API_KEY=
LLM_BACKUP_BASE_URL=https://api.openai.com/v1
LLM_BACKUP_MODEL=gpt-4o-mini
LLM_BACKUP_TIMEOUT_MS=60000

# LLM task 总超时（可选）
# provider timeout 控制单个 provider 最多等多久；task timeout 控制一次完整任务最多等多久。
# 多 provider fallback 时，task timeout 是 primary + backup 的总预算。
LLM_SEMANTIC_ROUTER_TIMEOUT_MS=20000
LLM_CHAT_SWITCH_TIMEOUT_MS=90000
LLM_STARTUP_TIMEOUT_MS=120000
LLM_DISCOVERY_TIMEOUT_MS=45000

### 可选变量

# 数据目录覆盖；留空时，正式运行用 repoRoot/data，测试自动用 repoRoot/data.test
CLAUDIO_DATA_DIR=

# OpenWeather API Key（启用实时天气）
OPENWEATHER_API_KEY=

# 实时天气默认位置；服务启动时会按这里拉取一次，并缓存给 LLM 使用
# 二选一即可：
# 1) 填城市名 + 国家码，例如 Panyu,Guangzhou + CN
# 2) 直接填经纬度
OPENWEATHER_DEFAULT_CITY=
OPENWEATHER_DEFAULT_COUNTRY=
OPENWEATHER_DEFAULT_LAT=
OPENWEATHER_DEFAULT_LON=

# 天气接口默认单位（standard | metric | imperial）
OPENWEATHER_DEFAULT_UNITS=metric

# 天气文案语言
OPENWEATHER_DEFAULT_LANG=zh_cn

# 天气接口超时（毫秒）
OPENWEATHER_TIMEOUT_MS=8000

# 天气缓存刷新间隔（毫秒），默认 60 分钟
OPENWEATHER_REFRESH_MS=3600000

# 日志级别（debug | info | warn | error）
LOG_LEVEL=info

# 本地音乐库；配置目录后会优先用本地文件解析播放，多个目录用系统路径分隔符分开
# Windows 示例：D:\Music;E:\Radio
# macOS/Linux 示例：/Users/me/Music:/Volumes/Library
LOCAL_MUSIC_ENABLED=
LOCAL_MUSIC_DIRS=
LOCAL_MUSIC_SCAN_CACHE_MS=60000
LOCAL_MUSIC_MAX_FILES=2000
